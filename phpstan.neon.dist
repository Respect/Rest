parameters:
  fileExtensions:
    - php
  level: 5
  paths:
    - src/
    - tests/
  ignoreErrors:
    # By-ref param type narrowing in match() — preg_match output type varies
    - message: '/Parameter &\$params by-ref type of method .+::match\(\)/'
      path: src/Routes/AbstractRoute.php
    # getReflection() null return required by abstract parent signature
    - message: '/never returns null so it can be removed from the return type/'
      paths:
        - src/Routes/Factory.php
        - src/Routes/Instance.php
    # Test issues — will be fixed during test modernization batch
    - message: '/Call to an undefined method/'
      path: tests/
    - message: '/Access to an undefined property/'
      path: tests/
    - message: '/will always evaluate to/'
      path: tests/
    - message: '/with return type void returns/'
      path: tests/
    - message: '/is unused/'
      path: tests/
    - message: '/Parameter #1 .+ expects resource/'
      path: tests/
    - message: '/invoked with 3 parameters, 2 required/'
      path: tests/
    - message: '/Anonymous function has an unused use/'
      path: tests/
    - message: '/Result of function header \(void\) is used/'
      path: tests/legacy/Respect/Rest/OldRouterTest.php
    - message: '/Call to an undefined static method Respect\\Rest\\Routes\\Factory::respond/'
      path: tests/legacy/Respect/Rest/Routes/AbstractRouteTest.php
    - message: '/Call to static method mediaType\(\) on an unknown class/'
      path: tests/legacy/Respect/Rest/Routes/AbstractRouteTest.php
    - message: '/Class Respect\\Rest\\Routes\\Factory referenced with incorrect case/'
      path: tests/legacy/Respect/Rest/Routes/AbstractRouteTest.php
